{
  "name": "@deadvault/sdk",
  "version": "0.2.0",
  "description": "Decentralized credential store SDK for AI agents, servers & scripts",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "keywords": [
    "deadvault",
    "vault",
    "password-manager",
    "credential-store",
    "ai-agent",
    "sdk",
    "blockchain",
    "web3",
    "encryption",
    "totp"
  ],
  "license": "MIT",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jo04ni/deadvault-sdk.git"
  },
  "homepage": "https://deadvault.xyz/",
  "bugs": {
    "url": "https://github.com/jo04ni/deadvault-sdk/issues"
  },
  "peerDependencies": {
    "viem": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "rimraf": "^6.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0",
    "viem": "^2.23.0",
    "vitest": "^4.0.18"
  }
}
